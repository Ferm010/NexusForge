<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Debug конфигурация (разрешить локальные сертификаты) -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
    
    <!-- Блокировка cleartext (HTTP) трафика -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
